{
  "manifest_version": 3,
  "name": "AI Webpage Tutor",
  "version": "1.0.0",
  "description": "Select any text on any webpage and instantly get explanations, quizzes, flashcards, diagrams, translations, and more.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://*.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Webpage Tutor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
